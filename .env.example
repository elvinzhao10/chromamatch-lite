# ============================================
# ChromaMatch Lite - API Keys Configuration
# ============================================
# Copy this file to .env and fill in your keys
# NEVER commit .env files to version control!

# ----- Stock Photo Search -----
# Get your key at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Get your key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# ----- AI Image Generation (Built-in Providers) -----
# Get your key at: https://platform.openai.com/api-keys
# Used by: openai, openai-gpt-image providers
OPENAI_API_KEY=

# Get your key at: https://aistudio.google.com/app/apikey
# Used by: google provider
GOOGLE_AI_KEY=

# Get your key at: https://platform.stability.ai/account/keys
# Used by: stability provider
STABILITY_API_KEY=

# Get your token at: https://replicate.com/account/api-tokens
# Used by: replicate provider
REPLICATE_API_TOKEN=

# Get your key at: https://nanobanana.com/api
# Used by: nanobanana, nanobanana-pro2 providers
NANOBANANA_API_KEY=

# ----- Custom Image Generation Providers -----
# Add env vars for custom providers registered via chromamatch_register_provider
# Example: MY_CUSTOM_MODEL_API_KEY=sk-xxx

# ----- MCP Server Configuration -----
MCP_SERVER_PORT=3456
MCP_SERVER_HOST=localhost

# ----- Transport Mode -----
# stdio (default): For Claude Desktop, Cursor, Windsurf, Codex CLI
# http: For browser, Trae HTTP mode, or custom clients
# MCP_TRANSPORT=stdio
